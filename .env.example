# Copy this file to .env and adjust as needed. All values shown are the defaults.

# Chat model served by Ollama (must be pulled first: `ollama pull qwen2.5:3b`)
LLM_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0

# Judge model for RAGAS evaluation. On CPU the default reuses the small chat
# model; if you can, use a larger model here for more reliable scores.
EVAL_MODEL=qwen2.5:3b

# Model for text-to-SQL generation — the hardest task in the pipeline for a
# small model (3B gets complex JOINs wrong). If your RAM allows, pull and use
# a larger one here: `ollama pull qwen2.5:7b`. Only the SQL route pays the
# extra latency; the rest of the agent stays on the fast small model.
SQL_MODEL=qwen2.5:3b

# Sentence-transformers embedding model (multilingual, CPU-friendly)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Retrieval
CHROMA_DIR=.chroma
CHROMA_COLLECTION=knowledge_base
DOCUMENTS_DIR=data/documents
RETRIEVAL_K=4
MAX_RETRIES=2

# SQL source
SQLITE_PATH=data/sample.db
# Directory scanned by `agentic-rag-ingest-csv` for CSV/Excel files to load as tables
TABLES_DIR=data/tables

# One-line descriptions the router uses to decide where to send a question.
# Update these when you index your own documents / database.
KB_DESCRIPTION=Documentation about Retrieval-Augmented Generation (RAG), agentic RAG patterns with LangGraph, and LLM evaluation with RAGAS.
SQL_DESCRIPTION=A SQLite database of a fictional online store with three tables: products (name, category, price), sales (product, quantity, date, country) and product_reviews (product, rating, country, review_date, comment).
